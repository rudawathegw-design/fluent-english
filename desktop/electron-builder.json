{
  "appId": "com.fluent.english",
  "productName": "Fluent",
  "copyright": "Fluent",
  "directories": { "output": "dist" },
  "files": ["main.js", "package.json"],
  "extraResources": [{ "from": "../www", "to": "www" }],
  "win": {
    "target": ["nsis"],
    "artifactName": "Fluent-Setup-${version}.${ext}"
